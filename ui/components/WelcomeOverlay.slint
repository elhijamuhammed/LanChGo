import { ListView } from "std-widgets.slint";

export component WelcomeOverlay inherits Rectangle {
    
    in-out property <bool> changed_networks;
    in-out property <string> selected_interface;
    in-out property <[string]> interfaces;
    in-out property <bool> show_welcome;
    in-out property <int> ui_port;
    in-out property <bool> manual_port_mode: false;
    in-out property <string> port_status: "";
    in-out property <float> global_scale;
    callback interface_selected(string);
    property <int> typed_port: root.ui_port;
    callback apply_manual_port(int);
    callback reset_port_to_auto();

    background: #00000080;

    VerticalLayout {
        Rectangle { vertical-stretch: 0.5; }

        HorizontalLayout {
            Rectangle { horizontal-stretch: 1; }

            Rectangle {
                width: 720px * root.global_scale;
                height: 390px * root.global_scale;
                border-radius: 20px * root.global_scale;
                background: #1e2128;
                border-width: 1px * root.global_scale;
                border-color: #3a3f48;
                drop-shadow-blur: 24px * root.global_scale;
                drop-shadow-color: #00000088;

                forward-focus: overlay_keys;
                overlay_keys := FocusScope {
                    width: parent.width;
                    height: parent.height;
                    key-pressed(event) => {
                        if event.text == Key.Return || event.text == Key.Escape {
                            root.interface_selected(root.selected_interface);
                            root.show_welcome = false;
                            return accept;
                        }
                        reject
                    }
                }
                
                VerticalLayout {
                    padding: 20px * root.global_scale;
                    spacing: 12px * root.global_scale;

                    // --- Title ---
                    VerticalLayout {
                        spacing: 2px * root.global_scale;
                        Text {
                            text: "Welcome to LanChGo";
                            color: white;
                            font-size: 19px * root.global_scale;
                            font-weight: 700;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: root.changed_networks
                                ? "Your network changed — pick an interface to continue."
                                : "Pick your network interface to get started.";
                            color: #666666;
                            font-size: 12px * root.global_scale;
                            horizontal-alignment: center;
                        }
                    }

                    // --- Interface Grid ---
                    HorizontalLayout {
                        spacing: 10px * root.global_scale;
                        height: 100px * root.global_scale;

                        for iface in root.interfaces: Rectangle {
                            horizontal-stretch: 1;
                            border-radius: 12px * root.global_scale;
                            border-width: 2px * root.global_scale;
                            border-color: root.selected_interface == iface ? #2b7bff : #2c2f35;
                            background: root.selected_interface == iface ? #1a3a6e : #2c2f35;
                            animate background { duration: 120ms; }
                            animate border-color { duration: 120ms; }

                            VerticalLayout {
                                padding: 10px * root.global_scale;
                                spacing: 6px * root.global_scale;
                                alignment: center;

                                HorizontalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 26px * root.global_scale;
                                        height: 26px * root.global_scale;
                                        border-radius: 13px * root.global_scale;
                                        background: root.selected_interface == iface ? #2b7bff : #3a3f48;
                                        animate background { duration: 120ms; }

                                        Text {
                                            text: "⬡";
                                            color: white;
                                            font-size: 13px * root.global_scale;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            width: parent.width;
                                            height: parent.height;
                                        }
                                    }
                                }

                                Text {
                                    text: iface;
                                    color: white;
                                    font-size: 11px * root.global_scale;
                                    horizontal-alignment: center;
                                    wrap: word-wrap;
                                }
                            }

                            TouchArea {
                                width: parent.width;
                                height: parent.height;
                                clicked => { root.selected_interface = iface; }
                            }
                        }
                    }

                    // --- Divider ---
                    Rectangle {
                        width: parent.width;
                        height: 1px * root.global_scale;
                        background: #2c2f35;
                    }

                    // --- Port Section ---
                    HorizontalLayout {
                        spacing: 10px * root.global_scale;

                        Text {
                            text: "UDP Port";
                            color: root.manual_port_mode ? #cccccc : #444444;
                            font-size: 13px * root.global_scale;
                            vertical-alignment: center;
                            animate color { duration: 150ms; }
                        }

                        Text {
                            text: root.manual_port_mode ? "" : "(Auto: " + root.ui_port + ")";
                            color: #444444;
                            font-size: 12px * root.global_scale;
                            vertical-alignment: center;
                        }

                        Rectangle { horizontal-stretch: 1; }

                        Text {
                            text: "Auto";
                            color: root.manual_port_mode ? #444444 : white;
                            font-size: 12px * root.global_scale;
                            vertical-alignment: center;
                            animate color { duration: 150ms; }
                        }

                        Rectangle {
                            width: 44px * root.global_scale;
                            height: 24px * root.global_scale;
                            border-radius: 12px * root.global_scale;
                            background: root.manual_port_mode ? #2b7bff : #3a3f48;
                            animate background { duration: 150ms; }

                            Rectangle {
                                width: 18px * root.global_scale;
                                height: 18px * root.global_scale;
                                border-radius: 9px * root.global_scale;
                                background: white;
                                x: root.manual_port_mode ? 23px * root.global_scale : 3px * root.global_scale;
                                y: 3px * root.global_scale;
                                animate x { duration: 150ms; }
                            }

                            TouchArea {
                                clicked => {
                                    if root.manual_port_mode {
                                        root.reset_port_to_auto(); // Rust handles setting manual_port_mode = false
                                        root.show_welcome = false;
                                    } else {
                                        root.manual_port_mode = true; // only flip when switching TO manual
                                    }
                                    root.port_status = "";
                                }
                            }
                        }

                        Text {
                            text: "Manual";
                            color: root.manual_port_mode ? white : #444444;
                            font-size: 12px * root.global_scale;
                            vertical-alignment: center;
                            animate color { duration: 150ms; }
                        }
                    }

                    // --- Port input row — always visible, disabled in auto ---
                    HorizontalLayout {
                        spacing: 8px * root.global_scale;

                        Rectangle {
                            width: 120px * root.global_scale;
                            height: 30px * root.global_scale;
                            border-radius: 6px * root.global_scale;
                            background: #12151a;
                            border-width: 1px * root.global_scale;
                            border-color: root.manual_port_mode ? #3a3f48 : #252830;
                            opacity: root.manual_port_mode ? 1.0 : 0.35;
                            animate opacity { duration: 150ms; }

                            TextInput {
                                width: parent.width - (16px * root.global_scale);
                                height: parent.height;
                                x: 8px * root.global_scale;
                                color: white;
                                font-size: 13px * root.global_scale;
                                input-type: number;
                                vertical-alignment: center;
                                text: root.typed_port;
                                enabled: root.manual_port_mode;
                                edited => {
                                    root.typed_port = self.text.to-float();
                                }
                            }
                        }

                        // Apply button
                        Rectangle {
                            width: 70px * root.global_scale;
                            height: 30px * root.global_scale;
                            border-radius: 6px * root.global_scale;
                            background: root.manual_port_mode
                                ? (apply_area.has-hover ? #3a8dff : #2b7bff)
                                : #2c2f35;
                            opacity: root.manual_port_mode ? 1.0 : 0.35;
                            animate opacity { duration: 150ms; }
                            animate background { duration: 150ms; }

                            Text {
                                text: "Apply";
                                color: white;
                                font-size: 12px * root.global_scale;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }

                            apply_area := TouchArea {
                                enabled: root.manual_port_mode;
                                clicked => { root.apply_manual_port(root.typed_port); }
                            }
                        }

                        // Reset button
                        Rectangle {
                            width: 70px * root.global_scale;
                            height: 30px * root.global_scale;
                            border-radius: 6px * root.global_scale;
                            background: root.manual_port_mode
                                ? (reset_area.has-hover ? #ff5555 : #3a3f48)
                                : #2c2f35;
                            opacity: root.manual_port_mode ? 1.0 : 0.35;
                            animate opacity { duration: 150ms; }
                            animate background { duration: 150ms; }

                            Text {
                                text: "Reset";
                                color: white;
                                font-size: 12px * root.global_scale;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }

                            reset_area := TouchArea {
                                enabled: root.manual_port_mode;
                                clicked => { 
                                    root.reset_port_to_auto();
                                    root.show_welcome = false;
                                 }
                            }
                        }

                        Text {
                            text: root.port_status;
                            color: root.port_status == "✅ Port available" ? #44cc77 : #ff5555;
                            font-size: 12px * root.global_scale;
                            vertical-alignment: center;
                        }
                    }

                    // --- Continue button ---
                    HorizontalLayout {
                        Rectangle { horizontal-stretch: 1; }

                        Rectangle {
                            width: 130px * root.global_scale;
                            height: 36px * root.global_scale;
                            border-radius: 10px * root.global_scale;
                            background: continue_area.has-hover ? #3a8dff : #2b7bff;
                            animate background { duration: 120ms; }

                            Text {
                                text: "Continue";
                                color: white;
                                font-size: 13px * root.global_scale;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }

                            continue_area := TouchArea {
                                width: parent.width;
                                height: parent.height;
                                clicked => {
                                    root.interface_selected(root.selected_interface);
                                    root.show_welcome = false;
                                }
                            }
                        }

                        Rectangle { horizontal-stretch: 1; }
                    }
                }
            }

            Rectangle { horizontal-stretch: 1; }
        }

        Rectangle { vertical-stretch: 1; }
    }
}
