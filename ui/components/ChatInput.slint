import { HorizontalBox, Button, TextEdit } from "std-widgets.slint";

export component ChatInput inherits HorizontalBox {
    spacing: 5px;

    in-out property <string> input_text;

    callback send_clicked();
    callback clear_clicked();
    callback open_command_picker();

    messageinput := TextEdit {
        text <=> root.input_text;
        wrap: word-wrap;
        height: 60px;
        horizontal-stretch: 1;
        font-size: 20px;
        placeholder-text: "Type here...";

        key-pressed(event) => {
            // ENTER (without Shift) → SEND
            if (event.text == "\n" || event.text == Key.Return) && !event.modifiers.shift {
                if root.input_text != "" {
                    root.send_clicked();
                }
                return accept;
            }

            // UP ARROW → OPEN COMMAND PICKER (only if empty)
            if (event.text == Key.UpArrow && root.input_text == "") || (event.text == Key.DownArrow && root.input_text == "") {
                root.open_command_picker();
                return accept;
            }

            reject
        }
    }

    // Auto-focus on load
    Timer {
        running: true;
        interval: 200ms;
        triggered => {
            messageinput.focus();
            self.running = false;
        }
    }

    Button {
        text: "Send";
        enabled: root.input_text != "";

        clicked => {
            root.send_clicked();
            messageinput.focus();
        }
    }

    Button {
        text: "Clear";

        clicked => {
            root.clear_clicked();
            messageinput.focus();
        }
    }
}
