import { HorizontalBox, VerticalBox } from "std-widgets.slint";

export component Toolbar inherits Rectangle {
    in-out property <string> channel_mode: "public";
    callback change_channel_mode(string);
    in-out property <float> global_scale;

    in-out property <bool> public_secure_helper: false;
    in-out property <string> host_PIN;
    in-out property <string> host_PIN_masked: "N/A";

    callback generate_new_PIN();
    in-out property <bool> show_welcome;
    in-out property <bool> web_session_active;
    callback disconnect_channel();

    callback request_open_create_or_join();
    callback request_close_create_or_join();
    callback request_show_pin();
    callback web_join_clicked();
    callback show_web_join_popup();

    callback set_public_mode();
    callback set_secure_mode();

    set_public_mode => {
        root.public_secure_helper = false;
        root.channel_mode = "public";
        root.change_channel_mode("public");
        root.host_PIN = "";
        root.host_PIN_masked = "N/A";
        root.request_close_create_or_join();
    }

    set_secure_mode => {
        root.public_secure_helper = true;
        root.channel_mode = "host";
        root.change_channel_mode("host");
        root.request_open_create_or_join();
    }

    background: #11161c;
    border-radius: 16px * root.global_scale;
    border-width: 1px * root.global_scale;
    border-color: #26313c;
    height: 68px * root.global_scale;

    HorizontalLayout {
        padding-left: 10px * root.global_scale;
        padding-right: 10px * root.global_scale;
        padding-top: 10px * root.global_scale;
        padding-bottom: 10px * root.global_scale;
        spacing: 8px * root.global_scale;
        alignment: center;

        // -------- Web Join / End Session — CYAN --------
        Rectangle {
            width: 120px * root.global_scale;
            height: 42px * root.global_scale;
            border-radius: 10px * root.global_scale;
            border-width: 1px * root.global_scale;
            border-color: root.channel_mode == "public"
                ? (root.web_session_active ? #7f1d1d : #0e7490)
                : #39424c;

            background: root.channel_mode == "public"
                ? (root.web_session_active
                    ? (web_join_area.pressed ? #b91c1c : web_join_area.has-hover ? #ef4444 : #dc2626)
                    : (web_join_area.pressed ? #00b4d8 : web_join_area.has-hover ? #35e4ff : #08d3f7))
                : #202831;

            Text {
                text: root.web_session_active ? "⛔ End Session" : "🌐 Web Join";
                color: root.channel_mode == "public" ? #0a0f14 : #8d98a3;
                font-size: 13px * root.global_scale;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
                width: parent.width;
                height: parent.height;
            }

            web_join_area := TouchArea {
                width: parent.width;
                height: parent.height;
                enabled: root.channel_mode == "public";
                clicked => { root.web_join_clicked(); }
            }
        }

        // -------- Mode Segmented Control — AMBER / TEAL --------
        Rectangle {
            width: 210px * root.global_scale;
            height: 42px * root.global_scale;
            border-radius: 12px * root.global_scale;
            background: #1a222b;
            border-width: 1px * root.global_scale;
            border-color: #2d3742;

            HorizontalLayout {
                padding: 3px * root.global_scale;
                spacing: 3px * root.global_scale;

                // Public — amber
                Rectangle {
                    border-radius: 9px * root.global_scale;
                    background: root.channel_mode == "public"
                        ? (pub_area.has-hover ? #ffb830 : #f0a500)
                        : (pub_area.has-hover ? #1e2d3d : #1a222b);
                    animate background { duration: 150ms; }

                    Text {
                        text: "🌍 Public";
                        color: root.channel_mode == "public" ? #0a0f14 : #a7b1bb;
                        font-size: 13px * root.global_scale;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: parent.width;
                        height: parent.height;
                        animate color { duration: 150ms; }
                    }

                    pub_area := TouchArea {
                        width: parent.width;
                        height: parent.height;
                        clicked => { root.set_public_mode(); }
                    }
                }

                // Secure — teal
                Rectangle {
                    border-radius: 9px * root.global_scale;
                    background: root.channel_mode == "host"
                        ? (sec_area.has-hover ? #00c9b0 : #00a896)
                        : (sec_area.has-hover ? #1e2d3d : #1a222b);
                    animate background { duration: 150ms; }

                    Text {
                        text: "🔒 Secure";
                        color: root.channel_mode == "host" ? #0a0f14 : #a7b1bb;
                        font-size: 13px * root.global_scale;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: parent.width;
                        height: parent.height;
                        animate color { duration: 150ms; }
                    }

                    sec_area := TouchArea {
                        width: parent.width;
                        height: parent.height;
                        clicked => { root.set_secure_mode(); }
                    }
                }
            }
        }

        // -------- PIN Info Chip --------
        Rectangle {
            width: 130px * root.global_scale;
            height: 42px * root.global_scale;
            border-radius: 10px * root.global_scale;
            background: #182028;
            border-width: 1px * root.global_scale;
            border-color: #2a3540;

            HorizontalLayout {
                padding-left: 10px * root.global_scale;
                padding-right: 10px * root.global_scale;
                spacing: 6px * root.global_scale;
                alignment: center;

                Text {
                    text: "PIN";
                    color: #8d98a3;
                    font-size: 12px * root.global_scale;
                    font-weight: 600;
                    vertical-alignment: center;
                }

                Text {
                    text: root.channel_mode == "public" ? "N/A" : root.host_PIN_masked;
                    color: root.channel_mode == "public" ? #6b7280 : #08d3f7;
                    font-size: 14px * root.global_scale;
                    font-weight: 700;
                    vertical-alignment: center;
                }
            }
        }

        // -------- Show PIN / Show Web — BLUE --------
        Rectangle {
            width: 108px * root.global_scale;
            height: 42px * root.global_scale;
            border-radius: 10px * root.global_scale;
            border-width: 1px * root.global_scale;
            border-color: (root.web_session_active || root.channel_mode == "host") ? #1d4ed8 : #39424c;
            background: (root.web_session_active || root.channel_mode == "host")
                ? (show_btn_area.has-hover ? #3b82f6 : #2563eb) : #202831;

            Text {
                text: root.web_session_active ? "🌐 Show Web" : "👁 Show PIN";
                color: (root.web_session_active || root.channel_mode == "host") ? white : #8d98a3;
                font-size: 13px * root.global_scale;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
                width: parent.width;
                height: parent.height;
            }

            show_btn_area := TouchArea {
                width: parent.width;
                height: parent.height;
                enabled: root.web_session_active || root.channel_mode == "host";
                clicked => {
                    if (root.web_session_active) {
                        root.show_web_join_popup();
                    } else {
                        root.request_show_pin();
                    }
                }
            }
        }

        // -------- New PIN — GREEN --------
        Rectangle {
            width: 100px * root.global_scale;
            height: 42px * root.global_scale;
            border-radius: 10px * root.global_scale;
            border-width: 1px * root.global_scale;
            border-color: root.channel_mode == "host" ? #166534 : #39424c;
            background: root.channel_mode == "host"
                ? (new_pin_area.has-hover ? #22c55e : #16a34a)
                : #202831;

            Text {
                text: "🔄 New PIN";
                color: root.channel_mode == "host" ? white : #8d98a3;
                font-size: 13px * root.global_scale;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
                width: parent.width;
                height: parent.height;
            }

            new_pin_area := TouchArea {
                width: parent.width;
                height: parent.height;
                enabled: root.channel_mode == "host";
                clicked => { root.generate_new_PIN(); }
            }
        }

        // -------- Disconnect — RED --------
        Rectangle {
            width: 108px * root.global_scale;
            height: 42px * root.global_scale;
            border-radius: 10px * root.global_scale;
            border-width: 1px * root.global_scale;
            border-color: root.channel_mode != "public" ? #7f1d1d : #39424c;
            background: root.channel_mode != "public"
                ? (disconnect_area.has-hover ? #ef4444 : #dc2626)
                : #202831;

            Text {
                text: "⏏ Disconnect";
                color: root.channel_mode != "public" ? white : #8d98a3;
                font-size: 13px * root.global_scale;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
                width: parent.width;
                height: parent.height;
            }

            disconnect_area := TouchArea {
                width: parent.width;
                height: parent.height;
                enabled: root.channel_mode != "public";
                clicked => { root.disconnect_channel(); }
            }
        }

        // -------- Settings — PURPLE --------
        Rectangle {
            width: 96px * root.global_scale;
            height: 42px * root.global_scale;
            border-radius: 10px * root.global_scale;
            border-width: 1px * root.global_scale;
            border-color: #4b0082;
            background: settings_area.has-hover ? #9370db : #6a5acd;

            Text {
                text: "⚙ Settings";
                color: white;
                font-size: 13px * root.global_scale;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
                width: parent.width;
                height: parent.height;
            }

            settings_area := TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => { root.show_welcome = true; }
            }
        }
    }
}
