import { HorizontalBox, VerticalBox } from "std-widgets.slint";

export component Toolbar inherits Rectangle {
    in-out property <string> channel_mode: "public";
    callback change_channel_mode(string);
    in-out property <float> global_scale;

    in-out property <bool> public_secure_helper: false;
    in-out property <string> host_PIN;
    in-out property <string> host_PIN_masked: "N/A";

    callback generate_new_PIN();
    in-out property <bool> show_welcome;
    in-out property <bool> web_session_active;
    callback disconnect_channel();

    callback request_open_create_or_join();
    callback request_close_create_or_join();
    callback request_show_pin();
    callback web_join_clicked();
    callback show_web_join_popup();

    callback set_public_mode();
    callback set_secure_mode();

    // Tools
    callback close_all_popups();
    close_all_popups => {
        root.web_popup_open = false;
        root.secure_popup_open = false;
        root.tools_popup_open = false; 
    }
    callback open_tools_devices_list(string, string, string);

    in-out property <bool> secure_popup_open: false;
    in-out property <bool> web_popup_open: false;
    in-out property <bool> tools_popup_open: false;

    set_public_mode => {
        root.public_secure_helper = false;
        root.channel_mode = "public";
        root.change_channel_mode("public");
        root.host_PIN = "";
        root.host_PIN_masked = "N/A";
        root.request_close_create_or_join();
        root.secure_popup_open = false;
        root.web_popup_open = false;
        root.tools_popup_open = false;
    }

    set_secure_mode => {
        root.public_secure_helper = true;
        root.channel_mode = "host";
        root.change_channel_mode("host");
        root.request_open_create_or_join();
        root.secure_popup_open = false;
        root.web_popup_open = false;
        root.tools_popup_open = false;
    }

    background: #11161c;
    border-radius: 16px * root.global_scale;
    border-width: 1px * root.global_scale;
    border-color: #26313c;
    height: 68px * root.global_scale;

    HorizontalLayout {
        padding-left: 10px * root.global_scale;
        padding-right: 10px * root.global_scale;
        padding-top: 10px * root.global_scale;
        padding-bottom: 10px * root.global_scale;
        spacing: 8px * root.global_scale;
        alignment: center;

        // -------- Web Button --------
        Rectangle {
            width: 128px * root.global_scale;
            height: 42px * root.global_scale;
            border-radius: 10px * root.global_scale;
            border-width: 1px * root.global_scale;

            border-color: root.channel_mode == "public"
                ? (root.web_session_active ? #16a34a : #0e7490)
                : #39424c;

            background: root.channel_mode == "public"
                ? (
                    root.web_session_active
                        ? (web_btn_area.has-hover ? #22c55e : #16a34a)
                        : (web_btn_area.has-hover ? #0ea5e9 : #0284c7)
                )
                : #202831;

            HorizontalLayout {
                alignment: center;
                spacing: 7px * root.global_scale;

                Text {
                    text: root.web_session_active ? "🌐 Web On" : "🌐 Web Off";
                    color: root.channel_mode == "public" ? white : #8d98a3;
                    font-size: 13px * root.global_scale;
                    font-weight: 700;
                    vertical-alignment: center;
                }

                Text {
                    text: root.web_popup_open ? "▲" : "▼";
                    color: root.channel_mode == "public" ? white : #8d98a3;
                    font-size: 13px * root.global_scale;
                    font-weight: 700;
                    vertical-alignment: center;
                }
            }

            web_btn_area := TouchArea {
                width: parent.width;
                height: parent.height;
                enabled: root.channel_mode == "public";
                clicked => {
                    root.secure_popup_open = false;
                    root.tools_popup_open = false;
                    root.web_popup_open = !root.web_popup_open;
                }
            }

            if root.web_popup_open: Rectangle {
                x: 0px;
                y: -(132px * root.global_scale);
                width: 190px * root.global_scale;
                height: 118px * root.global_scale;
                background: #11161c;
                border-radius: 12px * root.global_scale;
                border-width: 1px * root.global_scale;
                border-color: #2a3540;
                drop-shadow-blur: 24px * root.global_scale;
                drop-shadow-color: #000000dd;
                drop-shadow-offset-y: 8px * root.global_scale;

                VerticalLayout {
                    padding: 8px * root.global_scale;
                    spacing: 6px * root.global_scale;

                    Rectangle {
                        height: 32px * root.global_scale;
                        border-radius: 8px * root.global_scale;
                        background: root.web_session_active ? #10251a : #182028;

                        Text {
                            text: root.web_session_active ? "● Web companion running" : "● Web companion stopped";
                            color: root.web_session_active ? #22c55e : #8d98a3;
                            font-size: 12px * root.global_scale;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                    }

                    Rectangle {
                        height: 32px * root.global_scale;
                        border-radius: 8px * root.global_scale;
                        border-width: 1px * root.global_scale;
                        border-color: root.web_session_active ? #1d4ed8 : #0e7490;
                        background: root.web_session_active
                            ? (show_web_btn.has-hover ? #3b82f6 : #2563eb)
                            : (show_web_btn.has-hover ? #06b6d4 : #0891b2);

                        Text {
                            text: root.web_session_active ? "🌐 Show Web" : "🌐 Start Web";
                            color: white;
                            font-size: 12px * root.global_scale;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }

                        show_web_btn := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => {
                                root.web_popup_open = false;
                                if (root.web_session_active) {
                                    root.show_web_join_popup();
                                } else {
                                    root.web_join_clicked();
                                }
                            }
                        }
                    }

                    Rectangle {
                        height: 32px * root.global_scale;
                        border-radius: 8px * root.global_scale;
                        border-width: 1px * root.global_scale;
                        border-color: root.web_session_active ? #7f1d1d : #39424c;
                        background: root.web_session_active
                            ? (end_web_btn.has-hover ? #ef4444 : #dc2626)
                            : #202831;

                        Text {
                            text: "⛔ Stop Web";
                            color: root.web_session_active ? white : #8d98a3;
                            font-size: 12px * root.global_scale;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }

                        end_web_btn := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            enabled: root.web_session_active;
                            clicked => {
                                root.web_popup_open = false;
                                root.web_join_clicked();
                            }
                        }
                    }
                }
            }
        }

        // -------- Public / Secure Segmented Control --------
        Rectangle {
            width: 210px * root.global_scale;
            height: 42px * root.global_scale;
            border-radius: 12px * root.global_scale;
            background: #1a222b;
            border-width: 1px * root.global_scale;
            border-color: #2d3742;

            HorizontalLayout {
                padding: 3px * root.global_scale;
                spacing: 3px * root.global_scale;

                Rectangle {
                    border-radius: 9px * root.global_scale;
                    background: root.channel_mode == "public"
                        ? (pub_area.has-hover ? #ffb830 : #f0a500)
                        : (pub_area.has-hover ? #1e2d3d : #1a222b);

                    Text {
                        text: "🌍 Public";
                        color: root.channel_mode == "public" ? #0a0f14 : #a7b1bb;
                        font-size: 13px * root.global_scale;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: parent.width;
                        height: parent.height;
                    }

                    pub_area := TouchArea {
                        width: parent.width;
                        height: parent.height;
                        clicked => { root.set_public_mode(); }
                    }
                }

                Rectangle {
                    border-radius: 9px * root.global_scale;
                    background: (root.channel_mode == "host" || root.channel_mode == "joined")
                        ? (sec_area.has-hover ? #00c9b0 : #00a896)
                        : (sec_area.has-hover ? #1e2d3d : #1a222b);

                    HorizontalLayout {
                        alignment: center;
                        spacing: 7px * root.global_scale;

                        Text {
                            text: "🔒 Secure";
                            color: (root.channel_mode == "host" || root.channel_mode == "joined") ? #0a0f14 : #a7b1bb;
                            font-size: 13px * root.global_scale;
                            font-weight: 700;
                            vertical-alignment: center;
                        }

                        if (root.channel_mode == "host" || root.channel_mode == "joined"): Text {
                            text: root.secure_popup_open ? "▲" : "▼";
                            color: #0a0f14;
                            font-size: 13px * root.global_scale;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                    }

                    sec_area := TouchArea {
                        width: parent.width;
                        height: parent.height;
                        clicked => {
                            root.web_popup_open = false;
                            root.tools_popup_open = false;

                            if (root.channel_mode == "host" || root.channel_mode == "joined") {
                                root.secure_popup_open = !root.secure_popup_open;
                            } else {
                                root.set_secure_mode();
                            }
                        }
                    }

                    if root.secure_popup_open: Rectangle {
                        x: 0px;
                        y: -(182px * root.global_scale);
                        width: 205px * root.global_scale;
                        height: 165px * root.global_scale;
                        background: #11161c;
                        border-radius: 12px * root.global_scale;
                        border-width: 1px * root.global_scale;
                        border-color: #2a3540;
                        drop-shadow-blur: 16px * root.global_scale;
                        drop-shadow-color: #000000aa;
                        drop-shadow-offset-y: 4px * root.global_scale;

                        VerticalLayout {
                            padding: 8px * root.global_scale;
                            spacing: 6px * root.global_scale;

                            Rectangle {
                                height: 32px * root.global_scale;
                                border-radius: 8px * root.global_scale;
                                background: #182028;

                                Text {
                                    text: "🔒 PIN: " + root.host_PIN_masked;
                                    color: #08d3f7;
                                    font-size: 13px * root.global_scale;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    width: parent.width;
                                    height: parent.height;
                                }
                            }

                            Rectangle {
                                height: 32px * root.global_scale;
                                border-radius: 8px * root.global_scale;
                                border-width: 1px * root.global_scale;
                                border-color: root.channel_mode == "host" ? #1d4ed8 : #39424c;
                                background: root.channel_mode == "host"
                                    ? (show_pin_btn.has-hover ? #3b82f6 : #2563eb)
                                    : #202831;

                                Text {
                                    text: "👁 Show PIN";
                                    color: root.channel_mode == "host" ? white : #8d98a3;
                                    font-size: 12px * root.global_scale;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    width: parent.width;
                                    height: parent.height;
                                }

                                show_pin_btn := TouchArea {
                                    width: parent.width;
                                    height: parent.height;
                                    enabled: root.channel_mode == "host";
                                    clicked => {
                                        root.secure_popup_open = false;
                                        root.request_show_pin();
                                    }
                                }
                            }

                            Rectangle {
                                height: 32px * root.global_scale;
                                border-radius: 8px * root.global_scale;
                                border-width: 1px * root.global_scale;
                                border-color: root.channel_mode == "host" ? #166534 : #39424c;
                                background: root.channel_mode == "host"
                                    ? (new_pin_btn.has-hover ? #22c55e : #16a34a)
                                    : #202831;

                                Text {
                                    text: "🔄 New PIN";
                                    color: root.channel_mode == "host" ? white : #8d98a3;
                                    font-size: 12px * root.global_scale;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    width: parent.width;
                                    height: parent.height;
                                }

                                new_pin_btn := TouchArea {
                                    width: parent.width;
                                    height: parent.height;
                                    enabled: root.channel_mode == "host";
                                    clicked => {
                                        root.generate_new_PIN();
                                        root.secure_popup_open = false;
                                    }
                                }
                            }

                            Rectangle {
                                height: 32px * root.global_scale;
                                border-radius: 8px * root.global_scale;
                                border-width: 1px * root.global_scale;
                                border-color: #7f1d1d;
                                background: disconnect_btn.has-hover ? #ef4444 : #dc2626;

                                Text {
                                    text: "⏏ Disconnect";
                                    color: white;
                                    font-size: 12px * root.global_scale;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    width: parent.width;
                                    height: parent.height;
                                }

                                disconnect_btn := TouchArea {
                                    width: parent.width;
                                    height: parent.height;
                                    clicked => {
                                        root.disconnect_channel();
                                        root.secure_popup_open = false;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        // -------- Tools Button --------
        Rectangle {
            width: 120px * root.global_scale;
            height: 42px * root.global_scale;
            border-radius: 10px * root.global_scale;
            border-width: 1px * root.global_scale;
            border-color: root.channel_mode == "public" ? #7c3aed : #39424c;
            background: root.channel_mode == "public" ? (tools_area.has-hover ? #8b5cf6 : #6d28d9) : #202831;
            HorizontalLayout {
                alignment: center;
                spacing: 7px * root.global_scale;

                Text {
                    text: "🧰 Tools";
                    color: root.channel_mode == "public" ? white : #8d98a3;
                    font-size: 13px * root.global_scale;
                    font-weight: 700;
                    vertical-alignment: center;
                }

                Text {
                    text: root.tools_popup_open ? "▲" : "▼";
                    color: root.channel_mode == "public" ? white : #8d98a3;
                    font-size: 13px * root.global_scale;
                    font-weight: 700;
                    vertical-alignment: center;
                }
            }
            tools_area := TouchArea {
                width: parent.width;
                height: parent.height;
                enabled: root.channel_mode == "public";
                clicked => {
                    root.web_popup_open = false;
                    root.secure_popup_open = false;
                    root.tools_popup_open = !root.tools_popup_open;
                }
            }
            if root.tools_popup_open: Rectangle {
                x: 0px;
                y: -(180px * root.global_scale);
                width: 220px * root.global_scale;
                height: 162px * root.global_scale;
                background: #11161c;
                border-radius: 12px * root.global_scale;
                border-width: 1px * root.global_scale;
                border-color: #2a3540;
                drop-shadow-blur: 16px * root.global_scale;
                drop-shadow-color: #000000aa;
                drop-shadow-offset-y: 4px * root.global_scale;

                VerticalLayout {
                    padding: 8px * root.global_scale;
                    spacing: 6px * root.global_scale;

                    Rectangle {
                        height: 32px * root.global_scale;
                        border-radius: 8px * root.global_scale;
                        background: #182028;

                        Text {
                            text: "🧰 LAN Tools";
                            color: #c4b5fd;
                            font-size: 13px * root.global_scale;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                    }

                    Rectangle {
                        height: 32px * root.global_scale;
                        border-radius: 8px * root.global_scale;
                        background: mouse_area.has-hover ? #2563eb : #202831;
                        border-width: 1px * root.global_scale;
                        border-color: mouse_area.has-hover ? #3b82f6 : #39424c;

                        HorizontalLayout {
                            padding-left: 12px * root.global_scale;
                            padding-right: 10px * root.global_scale;
                            spacing: 8px * root.global_scale;
                            alignment: center;

                            Text {
                                text: "🖱";
                                font-size: 13px * root.global_scale;
                                vertical-alignment: center;
                            }

                            Text {
                                text: "Phone Mouse";
                                color: white;
                                font-size: 12px * root.global_scale;
                                font-weight: 700;
                                vertical-alignment: center;
                            }

                            Rectangle { width: 1px; }

                            Text {
                                text: "›";
                                color: mouse_area.has-hover ? white : #6b7280;
                                font-size: 18px * root.global_scale;
                                font-weight: 700;
                                vertical-alignment: center;
                            }
                        }

                        mouse_area := TouchArea {
                            width: parent.width;
                            height: parent.height;

                            clicked => {
                                root.tools_popup_open = false;
                                root.open_tools_devices_list("Phone Mouse", "🖱", "remote_input");
                            }
                        }
                    }

                    Rectangle {
                        height: 32px * root.global_scale;
                        border-radius: 8px * root.global_scale;
                        background: keyboard_area.has-hover ? #4338ca : #202831;
                        border-width: 1px * root.global_scale;
                        border-color: keyboard_area.has-hover ? #6366f1 : #39424c;

                        HorizontalLayout {
                            padding-left: 12px * root.global_scale;
                            padding-right: 10px * root.global_scale;
                            spacing: 8px * root.global_scale;
                            alignment: center;

                            Text {
                                text: "⌨";
                                font-size: 13px * root.global_scale;
                                vertical-alignment: center;
                            }

                            Text {
                                text: "Phone Keyboard";
                                color: white;
                                font-size: 12px * root.global_scale;
                                font-weight: 700;
                                vertical-alignment: center;
                            }

                            Rectangle { width: 1px; }

                            Text {
                                text: "›";
                                color: keyboard_area.has-hover ? white : #6b7280;
                                font-size: 18px * root.global_scale;
                                font-weight: 700;
                                vertical-alignment: center;
                            }
                        }

                        keyboard_area := TouchArea {
                            width: parent.width;
                            height: parent.height;

                            clicked => {
                                root.tools_popup_open = false;
                                root.open_tools_devices_list("Phone Keyboard", "⌨", "remote_input");
                            }
                        }
                    }

                    // Rectangle {
                    //     height: 32px * root.global_scale;
                    //     border-radius: 8px * root.global_scale;
                    //     background: share_area.has-hover ? #0f766e : #202831;
                    //     border-width: 1px * root.global_scale;
                    //     border-color: share_area.has-hover ? #14b8a6 : #39424c;

                    //     // HorizontalLayout {
                    //     //     padding-left: 12px * root.global_scale;
                    //     //     padding-right: 10px * root.global_scale;
                    //     //     spacing: 8px * root.global_scale;
                    //     //     alignment: center;

                    //     //     Text {
                    //     //         text: "📱";
                    //     //         font-size: 13px * root.global_scale;
                    //     //         vertical-alignment: center;
                    //     //     }

                    //     //     Text {
                    //     //         text: "Screen Mirror";
                    //     //         color: white;
                    //     //         font-size: 12px * root.global_scale;
                    //     //         font-weight: 700;
                    //     //         vertical-alignment: center;
                    //     //     }

                    //     //     Rectangle { width: 1px; }

                    //     //     Text {
                    //     //         text: "›";
                    //     //         color: share_area.has-hover ? white : #6b7280;
                    //     //         font-size: 18px * root.global_scale;
                    //     //         font-weight: 700;
                    //     //         vertical-alignment: center;
                    //     //     }
                    //     // }

                    //     share_area := TouchArea {
                    //         width: parent.width;
                    //         height: parent.height;

                    //         clicked => {
                    //             root.tools_popup_open = false;
                    //             root.open_tools_devices_list("Screen Share", "🖥", "screen_share");
                    //         }
                    //     }
                    // }
                }
            }
        }

        // -------- Settings --------
        Rectangle {
            width: 96px * root.global_scale;
            height: 42px * root.global_scale;
            border-radius: 10px * root.global_scale;
            border-width: 1px * root.global_scale;
            border-color: #4b0082;
            background: settings_area.has-hover ? #9370db : #6a5acd;

            Text {
                text: "⚙ Settings";
                color: white;
                font-size: 13px * root.global_scale;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
                width: parent.width;
                height: parent.height;
            }

            settings_area := TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => {
                    root.secure_popup_open = false;
                    root.web_popup_open = false;
                    root.tools_popup_open = false;
                    root.show_welcome = true;
                }
            }
        }
    }
}
