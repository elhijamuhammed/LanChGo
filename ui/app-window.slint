import { VerticalBox, HorizontalBox, LineEdit, Button, Switch, Slider, TextEdit, ListView } from "std-widgets.slint";
import { ChatPanel } from "components/ChatPanel.slint";
import { ChatInput } from "components/ChatInput.slint";
import { HeaderBar } from "components/HeaderBar.slint";
import { StatusBadge } from "components/StatusBadges.slint";
import { WelcomeOverlay } from "components/WelcomeOverlay.slint";
import { Toolbar } from "components/Toolbar.slint";
import { FileTransferPanel } from "components/FileTransferPanel.slint";
import { FileOfferItem } from "components/types.slint";
import { EscCloseHandler } from "components/HelpFunctions.slint";
import { DevicesList, ToolDevice } from "components/Tools/DevicesList.slint";

export component AppWindow inherits Window {
    width: 1000px * root.global_scale;
    height: 720px * root.global_scale;
    title: "LanChGo";
    icon: @image-url("assets/LanChGo_icon.png");
    forward-focus: main_key_handler;

    // Reactive list provided by Rust (ModelRc)
    in-out property <[string]> messages;
    in-out property <string> input_text;
    callback clear_chatbox();

    // Interface selection
    in-out property <bool> show_welcome;
    in-out property <[string]> interfaces;
    in-out property <string> selected_interface;
    callback interface_selected(string);
    in-out property <bool> changed_networks;
    in-out property <string> broadcast_address;
    in-out property <string> interface_status;
    in-out property <int> ui_port;

    // Security / channel status
    in-out property <string> channel_mode: "public";
    callback change_channel_mode(string);
    callback fix_the_bug_please();
    in-out property <bool> public_secure_helper: false;
    callback create_channel();
    in-out property <string> host_PIN;
    in-out property <string> host_PIN_masked: "N/A";
    callback generate_new_PIN();
    callback disconnect_channel();
    in property <image> QR_code_image;

    // Joiner logic
    in-out property <string> joining_PIN;
    callback join_channel(string);
    callback REQA();
    callback show_connecting_popup();
    callback hide_connecting_popup();
    show_connecting_popup => { connectingpopup.show(); }
    hide_connecting_popup => { connectingpopup.close(); }

    // Temporary message callback
    in-out property <string> temp_message: "";
    callback show_temp_message(string);
    show_temp_message(msg) => {
        hide_temp.stop();
        root.temp_message = "";
        root.temp_message = msg;
        hide_temp.start();
    }

    // Logic for the new version
    callback show_new_version_popup();
    callback exit_app();
    show_new_version_popup => { newversion.show(); }

    // Backend will call this to append a message safely on UI thread
    callback append_message(string);

    // popup API
    in-out property <string> popup_msg: "Message too long, it will not be sent!\nClick to dismiss.";
    callback send_clicked();
    callback show_popupmsg();
    show_popupmsg => { msgtoolongpopup.show(); }
    callback web_join_clicked();
    callback show_web_join_popup();
    show_web_join_popup => { webjoinpopup.show(); }

    // web join buttons and UI logic
    in-out property <bool> web_join_enabled: true;
    in-out property <bool> web_session_active: false;
    in-out property <bool> link_copied: false;
    callback copy_web_url();
    in-out property <string> url_link;

    // ---------------- File transfer ----------------
    callback pick_files_send();
    callback pick_download_folder();
    callback open_download_folder();
    in-out property <[FileOfferItem]> file_offer: [];
    callback add_file_offer(FileOfferItem);
    callback clear_file_transfer_panel();
    callback download_offer(string);
    in-out property <string> download_folder;
    callback debug_add_fake_offer_msg();

    // bundling progress
    in-out property <bool> bundle_in_progress: false;
    in-out property <float> bundle_progress: 0.0;
    in-out property <string> bundle_progress_text: "";

    // Download Progress
    in-out property <bool> download_in_progress: false;
    in-out property <float> download_progress: 0.0;
    in-out property <string> download_progress_text: "";

    // version
    in-out property <string> show_version;
    property <int> debug_offer_counter: 0;

    // Command picker
    in-out property <[string]> chat_commands: [
        "/info", "/rescale", "/help", "/settings", "/downloads", "/clearall", "/secure", "/disconnect", "/webjoin", "/webstop", "/restart", "/exit" 
    ];
    property <int> selected_command_idx: 0;

    // setting port manually
    in-out property <bool> manual_port_mode: false;
    in-out property <string> port_status: "";
    callback apply_manual_port(int);
    callback reset_port_to_auto();

    // update available
    in-out property <bool> update_available: false;
    in-out property <string> latest_version: "";

    // global factor scale
    in-out property <float> global_scale: 1.0;

    // wiring secure button to a command
    callback request_open_create_or_join();
    request_open_create_or_join => { createorjoinpopup.show(); }

    // Tools
    in-out property <bool> tools_device_list_open: false;
    in-out property <string> tools_device_list_title: "";
    in-out property <string> tools_device_list_icon: "";
    in-out property <string> active_tool: "";
    in-out property <int> active_tool_count: 0;
    callback open_tools_devices_list(string, string, string);
    in-out property <[ToolDevice]> tool_devices: [];
    callback add_tool_device(string, string, string, string, int, int, string, string);
    callback tool_device_selected(string);
    callback refresh_tool_devices();
    callback clear_tool_devices();
    in-out property <string> connected_device_id: "";
    callback disconnect_clicked();

    open_tools_devices_list(title, icon, tool_id) => {
        root.tools_device_list_title = title;
        root.tools_device_list_icon = icon;
        root.active_tool = tool_id;
        root.tools_device_list_open = true;
    }

    Rectangle {
        background: blue;
        border-width: 3px * root.global_scale;
        border-bottom-left-radius: 3px * root.global_scale;
        border-color: white;

        // ---------- Main UI ----------
        Rectangle {
            background: #111318;

            // Floating status badge
            StatusBadge {
                show_welcome: root.show_welcome;
                interfaces: root.interfaces;
                selected_interface: root.selected_interface;
                channel_mode <=> root.channel_mode;
                broadcast_address: root.broadcast_address;
                interface_status: root.interface_status;
                global_scale: root.global_scale;
            }

            // ESC to close toolbar popups
            main_key_handler := FocusScope {
                key-pressed(event) => {
                    if event.text == Key.Escape {
                        if root.tools_device_list_open {
                            root.tools_device_list_open = false;
                            return accept;
                        }

                        toolbar-inst.close_all_popups();
                        return accept;
                    }

                    reject
                }
            }

            VerticalBox {
                spacing: 12px * root.global_scale;

                HeaderBar {
                    show_version: root.show_version;
                    global_scale: root.global_scale;
                }

                if root.show_welcome: WelcomeOverlay {
                    width: parent.width;
                    height: parent.height;
                    global_scale: root.global_scale;
                    changed_networks <=> root.changed_networks;
                    selected_interface <=> root.selected_interface;
                    interfaces <=> root.interfaces;
                    show_welcome <=> root.show_welcome;
                    ui_port <=> root.ui_port;
                    manual_port_mode <=> root.manual_port_mode;
                    interface_selected() => { root.interface_selected(root.selected_interface); }
                    apply_manual_port (port) => { root.apply_manual_port(port); }
                    reset_port_to_auto () => { root.reset_port_to_auto(); }
                }

                // ======= MAIN ROW: Chat + File transfers =======
                Rectangle {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    background: transparent;

                    HorizontalBox {
                        spacing: 12px * root.global_scale;
                        width: parent.width;
                        height: parent.height;

                        ChatPanel {
                            horizontal-stretch: 1;
                            vertical-stretch: 1;
                            messages: root.messages;
                            temp_message: root.temp_message;
                            update_available <=> root.update_available;
                            latest_version <=> root.latest_version;
                            global_scale: root.global_scale;
                        }

                        VerticalBox {
                            spacing: 8px * root.global_scale;
                            vertical-stretch: 1;

                            FileTransferPanel {
                                vertical-stretch: 1;
                                global_scale: root.global_scale;
                                file_offer <=> root.file_offer;
                                download_folder <=> root.download_folder;
                                bundle_in_progress: root.bundle_in_progress;
                                bundle_progress: root.bundle_progress;
                                bundle_progress_text: root.bundle_progress_text;
                                download_in_progress: root.download_in_progress;
                                download_progress: root.download_progress;
                                download_progress_text: root.download_progress_text;

                                pick_files() => { root.pick_files_send(); }
                                pick_download_folder => { root.pick_download_folder(); }
                                open_download_folder() => { root.open_download_folder(); }
                                clear_offers() => { root.clear_file_transfer_panel(); }
                                download_offer(id) => { root.download_offer(id); }
                            }
                        }
                    }

                    // click outside toolbar popups closes them without becoming a VerticalBox layout item.
                    if toolbar-inst.web_popup_open || toolbar-inst.secure_popup_open || toolbar-inst.tools_popup_open: TouchArea {
                        width: parent.width;
                        height: parent.height;
                        clicked => {
                            toolbar-inst.close_all_popups();
                        }
                    }
                }

                toolbar-inst := Toolbar {
                    global_scale: root.global_scale;
                    channel_mode <=> root.channel_mode;
                    public_secure_helper <=> root.public_secure_helper;
                    host_PIN <=> root.host_PIN;
                    host_PIN_masked <=> root.host_PIN_masked;
                    show_welcome <=> root.show_welcome;
                    web_session_active <=> root.web_session_active;

                    change_channel_mode(mode) => { root.change_channel_mode(mode); }
                    generate_new_PIN() => { root.generate_new_PIN(); }
                    disconnect_channel() => { root.disconnect_channel(); }

                    request_open_create_or_join() => { createorjoinpopup.show(); }
                    request_close_create_or_join() => { createorjoinpopup.close(); }
                    request_show_pin() => { showpin.show(); }
                    web_join_clicked() => { root.web_join_clicked(); }
                    show_web_join_popup() => { webjoinpopup.show(); }

                    open_tools_devices_list(title, icon, tool_id) => {
                        root.tools_device_list_title = title;
                        root.tools_device_list_icon = icon;
                        root.active_tool = tool_id;
                        root.tools_device_list_open = true;
                    }
                }

                //--- Input row ---
                ChatInput {
                    global_scale: root.global_scale;
                    input_text <=> root.input_text;
                    send_clicked() => { root.send_clicked(); }
                    clear_clicked() => { clearchatbox.show(); }
                    open_command_picker() => {
                        root.selected_command_idx = 0;
                        commandpicker.show();
                    }
                }
            }
            // --- Tools Device List Popup ---
            if root.tools_device_list_open: FocusScope {
                width: parent.width;
                height: parent.height;

                init => {
                    self.focus();
                }

                key-pressed(event) => {
                    if event.text == Key.Escape {
                        root.tools_device_list_open = false;
                        return accept;
                    }

                    reject
                }

                Rectangle {
                    width: parent.width;
                    height: parent.height;
                    background: #00000080;

                    TouchArea {
                        width: parent.width;
                        height: parent.height;

                        clicked => {
                            root.tools_device_list_open = false;
                        }
                    }

                    Rectangle {
                        width: 500px * root.global_scale;
                        height: 490px * root.global_scale;

                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;

                        background: transparent;

                        TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => { }
                        }

                        DevicesList {
                            width: parent.width;
                            height: parent.height;

                            global_scale: root.global_scale;
                            tool_title: root.tools_device_list_title;
                            tool_icon: root.tools_device_list_icon;
                            devices <=> root.tool_devices;
                            active_tool: root.active_tool;
                            active_tool_count <=> root.active_tool_count;
                            connected_device_id <=> root.connected_device_id;
                            disconnect_clicked() => { root.disconnect_clicked(); }
                            close_clicked() => { root.tools_device_list_open = false; }
                            clear_tool_devices() => { root.clear_tool_devices(); }
                            device_selected(id) => {
                                root.tool_device_selected(id);
                                root.tools_device_list_open = false;
                            }
                        }
                    }
                }
            }
        }
    }

    // --- Message too long ---
    msgtoolongpopup := PopupWindow {
        width: 500px * root.global_scale;
        height: 250px * root.global_scale;
        close-policy: no-auto-close;
        forward-focus: esc_msg;
        esc_msg := EscCloseHandler { close_me => { msgtoolongpopup.close(); } }
        Rectangle {
            width: 500px * root.global_scale;
            min-height: 250px * root.global_scale;
            x: (((parent.width) / 2) - 50px * root.global_scale);
            y: (((parent.height) / 2) - 50px * root.global_scale);
            background: #00000066;
            border-radius: 12px * root.global_scale;

            Text {
                width: parent.width - 32px * root.global_scale;
                x: 16px * root.global_scale; y: 16px * root.global_scale;
                text: root.popup_msg;
                font-size: 24px * root.global_scale;
                color: white;
                horizontal-alignment: center;
                wrap: word-wrap;
            }
        }
        TouchArea {
            width: 100%;
            height: 100%;
            clicked => { msgtoolongpopup.close(); }
        }
    }

    // --- Create or Join ---
    createorjoinpopup := PopupWindow {
        width: parent.width;
        height: parent.height;
        close-policy: no-auto-close;
        forward-focus: esc_create;
        esc_create := EscCloseHandler {
            close_me => {
                root.channel_mode = "public";
                root.public_secure_helper = false;
                root.fix_the_bug_please();
                createorjoinpopup.close();
            }
        }
        Rectangle {
            width: parent.width;
            height: parent.height;
            background: #00000080;
            TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => { }
            }
        }
        Rectangle {
            width: 420px * root.global_scale;
            height: 280px * root.global_scale;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            border-radius: 16px * root.global_scale;
            background: #2c2f35;
            border-width: 1px * root.global_scale;
            border-color: #3a3f48;

            VerticalBox {
                spacing: 18px * root.global_scale;
                padding: 20px * root.global_scale;

                Text {
                    text: "Create or Join a Channel";
                    font-size: 22px * root.global_scale;
                    color: white;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                Button {
                    text: "🛡 Create Channel";
                    horizontal-stretch: 1;
                    height: 40px * root.global_scale;
                    clicked => {
                        root.create_channel();
                        root.change_channel_mode("host");
                        createorjoinpopup.close();
                    }
                }

                Rectangle {
                    height: 1px * root.global_scale;
                    background: #444;
                    width: parent.width;
                    opacity: 0.6;
                }

                VerticalBox {
                    spacing: 6px * root.global_scale;

                    Text {
                        text: "Join with PIN:";
                        font-size: 16px * root.global_scale;
                        color: #dddddd;
                    }

                    HorizontalBox {
                        spacing: 8px * root.global_scale;

                        line-edit := LineEdit {
                            text <=> joining_PIN;
                            placeholder-text: "Enter 8-digit PIN…";
                            horizontal-stretch: 1;
                            height: 36px * root.global_scale;
                            input-type: number;
                            read-only: joining_PIN.character-count >= 8;

                            key-pressed(event) => {
                                if (event.text == Key.Backspace) {
                                    line-edit.read-only = false;
                                    return EventResult.reject;
                                }
                                if (joining_PIN.character-count >= 8) {
                                    self.read-only = true;
                                }
                                if (event.text == Key.Escape) {
                                    createorjoinpopup.close();
                                    root.channel_mode = "public";
                                    return EventResult.accept;
                                }
                                if (event.text == Key.Return && joining_PIN.character-count == 8) {
                                    root.join_channel(joining_PIN);
                                    createorjoinpopup.close();
                                    return EventResult.accept;
                                }
                                return EventResult.reject;
                            }

                            accepted(text) => {
                                if (text.character-count == 8) {
                                    root.join_channel(text);
                                    createorjoinpopup.close();
                                }
                            }
                        }

                        Button {
                            text: "🔑 Join";
                            height: 36px * root.global_scale;
                            clicked => {
                                root.join_channel(joining_PIN);
                                createorjoinpopup.close();
                            }
                        }
                    }

                    Button {
                        text: "❌ Close";
                        horizontal-stretch: 1;
                        height: 36px * root.global_scale;
                        clicked => {
                            root.channel_mode = "public";
                            root.public_secure_helper = false;
                            root.fix_the_bug_please();
                            createorjoinpopup.close();
                        }
                    }
                }
            }
        }
    }

    // --- Web Join ---
    webjoinpopup := PopupWindow {
        width: parent.width;
        height: parent.height;
        close-policy: no-auto-close;
        forward-focus: esc_web;
        esc_web := EscCloseHandler {
            close_me => { webjoinpopup.close(); }
        }
        Rectangle {
            width: parent.width;
            height: parent.height;
            background: #00000080;
            TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => { }
            }
        }
        Rectangle {
            width: 440px * root.global_scale;
            height: 420px * root.global_scale;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            border-radius: 18px * root.global_scale;
            background: #2c2f35;
            border-width: 1px * root.global_scale;
            border-color: #3a3f48;

            VerticalBox {
                padding: 22px * root.global_scale;
                spacing: 14px * root.global_scale;

                Text {
                    text: "Web Join QR Code";
                    font-size: 22px * root.global_scale;
                    font-weight: 700;
                    color: white;
                    horizontal-alignment: center;
                }

                Text {
                    text: "Open the Web Companion in LanChGo's web page";
                    font-size: 14px * root.global_scale;
                    color: #c9ced6;
                    wrap: word-wrap;
                    horizontal-alignment: center;
                }

                Text {
                    text: "Scan this QR code with your phone to open Web Join.";
                    font-size: 14px * root.global_scale;
                    color: #c9ced6;
                    wrap: word-wrap;
                    horizontal-alignment: center;
                }

                Rectangle {
                    horizontal-stretch: 1;
                    height: 190px * root.global_scale;
                    border-radius: 14px * root.global_scale;
                    background: #1f2228;
                    border-width: 1px * root.global_scale;
                    border-color: #3a3f48;

                    Image {
                        source: root.QR_code_image;
                        width: 160px * root.global_scale;
                        height: 160px * root.global_scale;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }
                }

                HorizontalLayout {
                    spacing: 6px * root.global_scale;
                    alignment: center;

                    Text {
                        text: "Can't scan? " + root.url_link;
                        font-size: 12px * root.global_scale;
                        color: #c9ced6;
                        vertical-alignment: center;
                    }

                    Text {
                        text: root.link_copied ? "✅ Copied" : "📋 Copy link";
                        font-size: 12px * root.global_scale;
                        font-weight: 600;
                        color: copy_area.has-hover ? #81d4fa : #4fc3f7;
                        vertical-alignment: center;

                        copy_area := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => {
                                root.copy_web_url();
                                root.link_copied = true;
                                reset_copy_timer.start();
                            }
                        }
                    }
                }

                Rectangle {
                    height: 1px * root.global_scale;
                    background: #3a3f48;
                }

                Button {
                    text: "Close";
                    horizontal-stretch: 1;
                    height: 38px * root.global_scale;
                    clicked => { webjoinpopup.close(); }
                }
            }
        }
    }

    // --- Show PIN ---
    showpin := PopupWindow {
        width: parent.width;
        height: parent.height;
        close-policy: no-auto-close;
        forward-focus: esc_pin;
        esc_pin := EscCloseHandler {
            close_me => { showpin.close(); }
        }
        Rectangle {
            width: parent.width;
            height: parent.height;
            background: #00000080;
        }
        Rectangle {
            width: 420px * root.global_scale;
            height: 360px * root.global_scale;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            border-radius: 16px * root.global_scale;
            background: #2c2f35;
            border-width: 1px * root.global_scale;
            border-color: #3a3f48;

            VerticalBox {
                spacing: 16px * root.global_scale;
                padding: 20px * root.global_scale;

                Text {
                    text: "Your Channel PIN:";
                    font-size: 18px * root.global_scale;
                    color: white;
                    horizontal-alignment: center;
                }

                TextInput {
                    text: root.host_PIN;
                    read-only: true;
                    horizontal-stretch: 1;
                    height: 38px * root.global_scale;
                    font-size: 22px * root.global_scale;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    color: #00e0ff;
                }

                Rectangle {
                    height: 180px * root.global_scale;
                    background: transparent;

                    Image {
                        source: root.QR_code_image;
                        width: 160px * root.global_scale;
                        height: 160px * root.global_scale;
                        horizontal-alignment: center;
                    }
                }

                Button {
                    text: "Close";
                    horizontal-stretch: 1;
                    clicked => { showpin.close(); }
                }
            }
        }
    }

    // --- Clear chat box ---
    clearchatbox := PopupWindow {
        width: parent.width;
        height: parent.height;
        close-policy: no-auto-close;
        forward-focus: esc_clear;
        esc_clear := EscCloseHandler {
            close_me => { clearchatbox.close(); }
        }
        Rectangle {
            width: 420px * root.global_scale;
            height: 200px * root.global_scale;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            border-radius: 16px * root.global_scale;
            background: #2c2f35;
            border-width: 1px * root.global_scale;
            border-color: #3a3f48;

            VerticalBox {
                spacing: 16px * root.global_scale;
                padding: 20px * root.global_scale;

                Text {
                    text: "Are you sure you want to clear the chat box?";
                    font-size: 20px * root.global_scale;
                    font-weight: 500;
                    color: #e4e4e4;
                    horizontal-alignment: center;
                }

                HorizontalBox {
                    spacing: 12px * root.global_scale;

                    Button {
                        text: "✅ Confirm";
                        horizontal-stretch: 1;
                        height: 40px * root.global_scale;
                        clicked => {
                            root.clear_chatbox();
                            clearchatbox.close();
                        }
                    }
                    Button {
                        text: "❌ Cancel";
                        horizontal-stretch: 1;
                        height: 40px * root.global_scale;
                        clicked => { clearchatbox.close(); }
                    }
                }
            }
        }
    }

    // --- New version detected ---
    newversion := PopupWindow {
        width: parent.width;
        height: parent.height;
        close-policy: no-auto-close;

        Rectangle {
            width: parent.width;
            height: parent.height;
            background: #00000080;

            Rectangle {
                width: 500px * root.global_scale;
                height: 240px * root.global_scale;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                border-radius: 16px * root.global_scale;
                background: #2c2f35;
                border-width: 1px * root.global_scale;
                border-color: #3a3f48;

                VerticalBox {
                    spacing: 18px * root.global_scale;
                    padding: 20px * root.global_scale;

                    Text {
                        text: "⚠️ Config file for an older version detected!";
                        font-size: 20px * root.global_scale;
                        font-weight: 600;
                        color: white;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }

                    Text {
                        text: "Please restart LanChGo to continue with a fresh configuration.";
                        font-size: 16px * root.global_scale;
                        color: #dddddd;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }

                    HorizontalBox {
                        Rectangle { horizontal-stretch: 1; }
                        Button {
                            text: "🚪 EXIT";
                            horizontal-stretch: 0;
                            width: 120px * root.global_scale;
                            height: 42px * root.global_scale;
                            clicked => { root.exit_app(); }
                        }
                        Rectangle { horizontal-stretch: 1; }
                    }
                }
            }
        }
    }

    // --- Connecting ---
    connectingpopup := PopupWindow {
        width: parent.width;
        height: parent.height;
        close-policy: no-auto-close;

        Rectangle {
            width: 300px * root.global_scale;
            height: 150px * root.global_scale;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            border-radius: 12px * root.global_scale;
            background: #2c2f35;

            VerticalBox {
                spacing: 12px * root.global_scale;
                Text { text: "Connecting to secure channel..."; color: white; horizontal-alignment: center; }
                Text { text: "🔄 Please wait"; color: #aaaaaa; horizontal-alignment: center; }
            }
        }
    }

    // --- Command Picker ---
    commandpicker := PopupWindow {
        width: parent.width;
        height: parent.height;
        close-policy: no-auto-close;
        forward-focus: cmd_keys;

        // Reset selection when opened
        init => {
            root.selected_command_idx = 0;
        }

        Rectangle {
            width: parent.width;
            height: parent.height;
            background: #00000080;

            TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => { commandpicker.close(); }
            }
        }

        Rectangle {
            width: 380px * root.global_scale;
            height:(56px * root.global_scale)
            + (1px * root.global_scale)
            + ((44px * root.chat_commands.length) * root.global_scale)
            + (32px * root.global_scale)
            + (40px * root.global_scale);
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            border-radius: 16px * root.global_scale;
            background: #2c2f35;
            border-width: 1px * root.global_scale;
            border-color: #3a3f48;

            VerticalBox {
                padding: 16px * root.global_scale;
                spacing: 10px * root.global_scale;

                Text {
                    text: "Commands";
                    font-size: 20px * root.global_scale;
                    font-weight: 600;
                    color: white;
                    horizontal-alignment: center;
                }

                Rectangle {
                    height: 1px * root.global_scale;
                    background: #3a3f48;
                }

                VerticalBox {
                    spacing: 4px * root.global_scale;

                    for cmd[index] in root.chat_commands: Rectangle {
                        height: 40px * root.global_scale;
                        border-radius: 8px * root.global_scale;
                        background: index == root.selected_command_idx ? #2b7bff : #1f2228;
                        border-width: index == root.selected_command_idx ? 1px * root.global_scale : 0px * root.global_scale;
                        border-color: #7fb2ff;

                        HorizontalBox {
                            spacing: 8px * root.global_scale;
                            padding-left: 12px * root.global_scale;
                            padding-right: 12px * root.global_scale;

                            Text {
                                text: index == root.selected_command_idx ? "▶" : "";
                                width: 20px * root.global_scale;
                                color: #ffffff;
                                font-size: 15px * root.global_scale;
                                vertical-alignment: center;
                            }

                            Text {
                                text: cmd;
                                color: white;
                                font-size: 15px * root.global_scale;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }

                            Text {
                                text: index == root.selected_command_idx ? "Enter" : "";
                                color: #d7e8ff;
                                font-size: 11px * root.global_scale;
                                vertical-alignment: center;
                            }
                        }

                        TouchArea {
                            width: parent.width;
                            height: parent.height;

                            clicked => {
                                root.input_text = cmd;
                                commandpicker.close();
                                root.send_clicked();
                            }
                        }
                    }
                }

                Text {
                    text: "↑ ↓ navigate    Enter execute    Esc close";
                    font-size: 11px * root.global_scale;
                    color: #9aa3b2;
                    horizontal-alignment: center;
                }
            }

            cmd_keys := FocusScope {
                width: parent.width;
                height: parent.height;

                key-pressed(event) => {

                    // 🔁 Wrap-around UP
                    if event.text == Key.UpArrow {
                        if root.selected_command_idx == 0 {
                            root.selected_command_idx = root.chat_commands.length - 1;
                        } else {
                            root.selected_command_idx -= 1;
                        }
                        return accept;
                    }

                    // 🔁 Wrap-around DOWN
                    if event.text == Key.DownArrow {
                        if root.selected_command_idx == root.chat_commands.length - 1 {
                            root.selected_command_idx = 0;
                        } else {
                            root.selected_command_idx += 1;
                        }
                        return accept;
                    }

                    // ✅ ENTER = EXECUTE
                    if event.text == "\n" || event.text == Key.Return {
                        root.input_text = root.chat_commands[root.selected_command_idx];
                        commandpicker.close();
                        root.send_clicked();
                        return accept;
                    }

                    // ❌ ESC = CLOSE
                    if event.text == Key.Escape {
                        commandpicker.close();
                        return accept;
                    }

                    reject
                }
            }
        }
    }
    
    // --- Timer to clear temporary messages ---
    hide_temp := Timer {
        interval: 3s;
        running: false;
        triggered => {
            root.temp_message = "";
            self.running = false;
        }
    }

    // --- General timer ---
    reset_copy_timer := Timer {
        interval: 1.5s;
        running: false;
        triggered => {
            root.link_copied = false;
            self.running = false;
        }
    }
}
